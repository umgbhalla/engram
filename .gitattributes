# GitHub linguist: keep the language bar reflecting authored product code.

# Vendored third-party code (quickjs dist, esbuilt stdlib bundles) — not ours.
apps/cloud/vendor/**      linguist-vendored
**/stdlib-src/*.js        linguist-vendored

# Test / bench / obs harnesses — not product source.
tests/**                  linguist-generated
experiments/**            linguist-generated
**/smoke*.mjs             linguist-generated
**/obs-*.mjs              linguist-generated
**/bench/**               linguist-generated

# Mermaid sources are authored product docs (NOT generated); the rendered .svg is generated.
docs/diagrams/*.mmd       -linguist-generated linguist-detectable

# Generated diagrams + required binary delivery artifacts.
docs/diagrams/*.svg       linguist-generated
*.wasm                    binary linguist-vendored

# Generated diagrams.
docs/diagrams/*.svg       linguist-generated

# Required binary delivery artifacts (already binary, but be explicit).
*.wasm                    binary linguist-vendored

# generated stdlib bundle
**/stdlib.bundle.txt    linguist-generated

# vendored rquickjs (patched: interrupt-counter 10000->64 for the buffer-growth tripwire)
apps/kernel/engine/vendor/**    linguist-vendored

# SDK dist is generated from src/index.ts
packages/sdk/dist/**    linguist-generated
