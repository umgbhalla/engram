# Proven experiments + test/bench harnesses — not product source.
experiments/**            linguist-generated
**/smoke*.mjs             linguist-generated
**/obs-*.mjs              linguist-generated
**/bench/**               linguist-generated

# Generated diagrams.
docs/diagrams/*.svg       linguist-generated

# Required binary delivery artifacts (already binary, but be explicit).
*.wasm                    binary linguist-vendored
