{
  "name": "@engram/sdk",
  "version": "2.0.0-rc.0",
  "description": "Clean, ergonomic TypeScript client for the durable Engram kernel \u2014 durable JS REPL sessions over WebSocket (kernel) or HTTP (cloud), with typed results and errors.",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --format=esm --platform=neutral --target=es2022 --external:node:* --outfile=dist/index.mjs && tsc --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "engram",
    "durable-object",
    "cloudflare",
    "repl",
    "quickjs",
    "sdk"
  ],
  "license": "MIT",
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "esbuild": "^0.24.0"
  }
}
