# Cloudflare credentials — copy to .env (gitignored), fill in.
# Workers PAID plan required for Dynamic Workers / Worker Loader (else error 10195).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# token scopes needed: Workers Scripts:Edit, Workers KV:Edit, Durable Objects, R2:Edit

# WorkOS AuthKit / CLI Auth — used by engram-cloud auth and engram CLI login.
# WORKOS_API_KEY is secret; WORKOS_CLIENT_ID / WORKOS_AUTHKIT_DOMAIN are public config.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_AUTHKIT_DOMAIN=
WORKOS_COOKIE_PASSWORD=

# Engram-issued short-lived token signing. Secret in Cloudflare, never committed filled-in.
ENGRAM_AUTH_JWT_SECRET=
ENGRAM_AUTH_ISSUER=https://engram-cloud.umg-bhalla88.workers.dev
