{
  "name": "engram",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "deploy:kernel": "wrangler deploy -c apps/kernel/wrangler.jsonc",
    "deploy:cloud": "wrangler deploy -c apps/cloud/wrangler.jsonc",
    "deploy:ui": "bun run --filter @engram/ui-app build && wrangler deploy -c apps/ui/wrangler.jsonc",
    "deploy:all": "bun scripts/deploy.ts",
    "e2e:ui": "node scripts/e2e-ui.mjs",
    "build:sdk": "bun run --filter @engram/sdk build",
    "build:cli": "bun run --filter @engram/cli build",
    "build:ui": "bun run --filter @engram/ui-app build"
  },
  "devDependencies": {
    "isomorphic-git": "1.27.1"
  }
}
