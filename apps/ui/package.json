{
  "name": "@engram/ui-app",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && esbuild src/worker.ts --bundle --format=esm --target=es2022 --loader:.html=text --outfile=dist/worker.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  }
}
