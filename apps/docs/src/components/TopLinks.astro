---
// Top-bar links: live demo + GitHub. Replaces Starlight's default social icons
// so we can render an explicit "Live demo" call-to-action alongside the repo link.
const LIVE_DEMO = "https://engram-ui.umg-bhalla88.workers.dev";
const REPO = "https://github.com/umgbhalla/montydyn";
---
<div class="top-links">
  <a class="cta" href={LIVE_DEMO} target="_blank" rel="noopener">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
    Live demo
  </a>
  <a class="icon" href={REPO} target="_blank" rel="noopener" aria-label="GitHub repository">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
  </a>
</div>

<style>
  .top-links { display: flex; align-items: center; gap: 0.75rem; }
  .cta {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.8rem; font-weight: 600;
    color: #0a0f1e; background: var(--sl-color-accent);
    padding: 0.35rem 0.7rem; border-radius: 8px;
    text-decoration: none; white-space: nowrap;
    transition: background 0.15s ease;
  }
  .cta:hover { background: #6aa8ff; }
  .icon { color: var(--sl-color-gray-2); display: inline-flex; transition: color 0.15s ease; }
  .icon:hover { color: var(--sl-color-white); }
</style>
