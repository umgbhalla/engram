{
  // Engram V1.1 — multi-tenant kernel via DO Facets, at v0.8 feature parity.
  // SupervisorDO (normal SQLite DO): routing + adaptive keep-warm + WS-proxy + worker_loaders
  //   + mediated per-tenant egress (HttpGateway WorkerEntrypoint as the facet globalOutbound).
  // Per-session KernelFacet (dynamically loaded via LOADER): own SQLite, {wasm} engine,
  //   configurable in-VM stdlib (lodash/dayjs/nanoid/uuid/zod, mathjs opt-in) + the 5 Tier-0
  //   native extensions (crypto.subtle/getRandomValues/randomUUID, TextEncoder/Decoder, URL,
  //   structuredClone, Headers) delivered via {text}/{js}/{wasm} loader modules.
  // CUTOVER (2026-06-03): apps/cloud is now the RUST-facet cloud. Authored source is now
  // TypeScript: src/supervisor.ts (SupervisorDO + HttpGateway + auth + keep-warm + metering +
  // facet loader). The build pipeline (scripts/build.mjs) runs: tsc --noEmit (strict) ->
  // bake-rust.ts (delivers apps/kernel Rust DO + engine.wasm into the facet via the {wasm}
  // Worker-Loader module type, generating src/modules.rust.gen.js) -> esbuild bundle
  // src/supervisor.ts -> dist/worker.mjs (the entry the runtime loads). Runtime behavior is
  // byte-identical to the prior src/supervisor-rust.js (kept for rollback reference).
  // Proven in experiments/cloud-rust, verified on scratch engram-cloud-rust2. Rollback anchor
  // (prior JS-kernel cloud) version: c06a77a1-d035-4153-a8b7-8bafe8953b3b.
  "name": "engram-cloud",
  "main": "dist/worker.mjs",
  "compatibility_date": "2026-04-01",
  // enable_ctx_exports exposes ctx.exports (DurableObjectState.exports) so the SupervisorDO can
  // instantiate its own HttpGateway WorkerEntrypoint (ctx.exports.HttpGateway({props:{tenant}}))
  // and hand it to each facet as globalOutbound. WITHOUT it ctx.exports is undefined ->
  // #egress() throws -> its try/catch falls back to globalOutbound:null -> the facet's outbound
  // fetch is fully blocked ("not permitted to access the internet via global functions like
  // fetch()"). This is the root cause of the mediated-egress FAIL. (Ref: context/dynos.)
  // enable_ctx_exports became the platform DEFAULT on 2025-11-17 (our compat_date 2026-04-01 is
  // past it), so it must NOT be listed explicitly — wrangler now errors 10021 if it is.
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  "build": {
    // tsc-typecheck (strict) -> bake-rust (generate src/modules.rust.gen.js with the Rust DO +
    // engine.wasm + stdlib facet payload) -> esbuild bundle src/supervisor.ts -> dist/worker.mjs.
    "command": "node scripts/build.mjs"
  },

  "durable_objects": {
    "bindings": [{ "name": "SUPERVISOR", "class_name": "SupervisorDO" }]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SupervisorDO"] }
  ],

  "worker_loaders": [
    { "binding": "LOADER" }
  ],

  // V1.1 mediated egress: optional coarse, tenant-wide host allow/deny for the HttpGateway
  // (the facet globalOutbound). Unset => the gateway forwards and the in-VM per-session
  // config.fetch allowlist is the control. Set MEDIATED_FETCH_ALLOW/DENY (comma hostnames)
  // to hard-restrict ALL egress at the supervisor seam.
  "vars": {
    "MEDIATED_FETCH_ALLOW": "",
    "MEDIATED_FETCH_DENY": "",
    // V1.2 metering: GET /usage queries the AE SQL API. The account id is non-secret (var);
    // CF_API_TOKEN + ADMIN_TOKEN are deployed as Worker SECRETS (wrangler secret put), never
    // committed. CF_ACCOUNT_ID also accepted as a secret/env; this var is the default.
    "CF_ACCOUNT_ID": "54a86ffba6a98141d2b1b4a1035334ed"
  },

  // Reuse pre-existing infra (namespaced v1/ keys). SQLite-first snapshot is in the
  // facet; R2 is the overflow target and AE is telemetry.
  "r2_buckets": [
    { "binding": "SNAPSHOTS", "bucket_name": "engram-snapshots" }
  ],
  "analytics_engine_datasets": [
    { "binding": "AE", "dataset": "engram_kernel" }
  ]
}
